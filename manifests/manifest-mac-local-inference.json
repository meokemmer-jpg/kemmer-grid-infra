    "t_life_impact_days": 0,
    "wargame_status": "alignment_passed (Masterplan v2: Mac = Phase 3, nicht Phase 1)",
    "crux_mandatory": "crux-check.sh vor jedem Ollama-Call und vor LAN-Publish",
