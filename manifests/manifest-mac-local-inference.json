    "k0_protection": "medium (Hardware-Investment 2500-3500 EUR einmalig, Break-Even 6-12 Monate)",
    "q0_protection": "high (Daten-Lokalitaet fuer K_0/Q_0-sensitive Tasks, kein Cloud-Leak)",
    "i_min_contribution": "positive (Tier-3-Redundanz im LLM-Grid, Fallback-Option)",
